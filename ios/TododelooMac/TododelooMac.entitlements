<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Native macOS app. Not sandboxed for local development, so outgoing network
	  (the JSON API) and the Keychain work without extra entitlements. For a
	  sandboxed App Store build, add com.apple.security.app-sandbox and
	  com.apple.security.network.client (see tuneflow's TuneFlowMac.entitlements).
	-->
</dict>
</plist>
